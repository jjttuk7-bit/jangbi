# OPENAI_API_KEY: OpenAI API 호출용 (진단 + 팀소피아 LLM).
#   서버 전용 — 서버리스 함수(api/diagnosis.ts, api/team-sophia.ts)와 로컬 server/index.ts 에서만 사용한다.
#   더 이상 클라이언트 번들에 주입되지 않으므로 브라우저에 노출되지 않는다.
#   Vercel 프로젝트 환경변수 및 로컬 .env.local 에 설정.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- 팀소피아 Slack 연동 ---
# SLACK_BOT_TOKEN: 팀소피아 내부 운영실 전송용 봇 토큰(xoxb-...).
#   서버에서만 사용하며 절대 프론트엔드 번들에 노출하지 않는다.
#   - 로컬: server/index.ts (npm run server)가 사용
#   - 배포: Vercel 서버리스 함수 api/slack.ts 가 사용 → Vercel 프로젝트 환경변수에 등록
#   봇은 #team-sophia-daily, #sophia, #anne-data, #claire-cs, #jane-marketer, #kelly-creator, #build-log 채널에 초대되어 있어야 한다.
#   필요한 스코프: chat:write
SLACK_BOT_TOKEN="xoxb-..."

# SERVER_PORT: 로컬 전용. Express 전송 서버 포트(기본 8787). Vite dev proxy(/api)가 이 포트로 연결된다.
#   Vercel 배포에서는 불필요(서버리스 함수가 /api/slack 을 직접 처리).
SERVER_PORT="8787"
